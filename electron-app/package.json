{
  "name": "nexus-electron-app",
  "version": "0.9.9",
  "description": "Electron application for Nexus Terminal",
  "main": "main.js",
  "author": {
    "name": "Heavrnl",
    "email": "heavrnl@example.com"
  },
  "homepage": "https://github.com/Heavrnl/nexus-terminal",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Heavrnl/nexus-terminal.git"
  },
  "license": "ISC",
  "optionalDependencies": {
    "dmg-license": "^1.0.10"
  },
  "dependencies": {
    "electron-store": "^10.0.1",
    "express": "^5.1.0",
    "http-proxy-middleware": "^3.0.7",
    "iconv-lite": "^0.6.3"
  },
  "scripts": {
    "start": "electron .",
    "build:backend": "cd ../packages/backend && npm run build",
    "build:frontend": "cd ../packages/frontend && npm run build",
    "prepare:node-runtime": "powershell -NoProfile -ExecutionPolicy Bypass -Command \"New-Item -ItemType Directory -Force -Path 'nodejs-runtime/win-x64' | Out-Null; Copy-Item -Path (Get-Command node).Source -Destination 'nodejs-runtime/win-x64/node.exe' -Force\"",
    "build:electron": "npm run prepare:node-runtime && electron-builder build --win --config",
    "build": "npm run build:frontend && npm run build:backend && npm run build:electron"
  },
  "devDependencies": {
    "electron": "^33.0.0",
    "electron-builder": "^25.0.0"
  },
  "build": {
    "appId": "com.heavrnl.nexus-terminal",
    "productName": "Nexus Terminal",
    "directories": {
      "output": "dist",
      "buildResources": "build"
    },
    "files": [
      "main.js",
      "preload.js",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "../packages/backend",
        "to": "packages/backend",
        "filter": [
          "dist/**",
          "html-presets/**"
        ]
      },
      {
        "from": "../packages/frontend/dist",
        "to": "packages/frontend/dist"
      },
      {
        "from": "nodejs-runtime",
        "to": "nodejs-runtime"
      }
    ],
    "win": {
      "target": [
        "nsis"
      ],
      "icon": "build/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "installerIcon": "build/icon.ico"
    },
    "includePdb": false
  }
}
