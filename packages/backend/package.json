      "adm-zip": "^0.5.16",
      "archiver": "^7.0.1",
      "archiver-zip-encrypted": "^2.0.0",
      "axios": "^1.18.1",
      "bcrypt": "^6.0.0",
      "date-fns": "^4.4.0",
      "date-fns-tz": "^3.2.0",
      "dotenv": "^16.5.0",
      "easyzip": "^1.0.3",
      "express": "^5.2.1",
      "express-session": "^1.19.0",
      "http-proxy-agent": "^9.1.0",
      "https-proxy-agent": "^9.1.0",
      "i18next": "^25.10.10",
      "i18next-fs-backend": "^2.6.6",
      "iconv-lite": "^0.6.3",
